{
  "info": {
    "name": "AI-Enabled Wound APIs - Doctor Side",
    "_postman_id": "doctor-side-ai-enabled-wound",
    "description": "Doctor-side Postman collection for auth, account request, home/patient management, wound details, task management, profile/settings, patient handoff, and notifications.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{doctorToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('status is not 500', function () {",
          "  pm.expect(pm.response.code).to.not.equal(500);",
          "});"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ],
